{
  "name": "@vibe-coalition/spore-code",
  "version": "1.1.0-beta.0",
  "description": "Spore Code npm/npx terminal client for Spore Core",
  "type": "module",
  "bin": {
    "spore": "./dist/bin/spore.js"
  },
  "files": [
    "dist/bin",
    "install.sh",
    "install.cmd",
    "install.ps1",
    "README.md",
    "LICENSE",
    "COMMERCIAL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin/spore.tsx",
    "prepack": "npm run build",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "smoke:live": "tsx src/bin/spore.tsx smoke",
    "pack:smoke": "npm run build && npm pack --dry-run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "license": "SEE LICENSE IN LICENSE"
}
